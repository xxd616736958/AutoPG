{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "postgres_mcp",
        "--access-mode=restricted"
      ],
      "env": {
        "DATABASE_URI": "postgresql://username:password@localhost:5432/dbname"
      }
    }
  }
}
