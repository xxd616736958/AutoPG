# db-claude database tuning agent configuration
# Copy to .env or export these variables in your shell.

# LLM provider config is also supported through ~/.db-claude/config.json.
DEEPSEEK_API_KEY=sk-...
DB_CLAUDE_PROVIDER=deepseek
DB_CLAUDE_MODEL=deepseek-v4-flash
DB_CLAUDE_BASE_URL=https://api.deepseek.com/v1

# Built-in postgres_mcp config
DB_CLAUDE_DATABASE_URI=postgresql://nncc@localhost:5432/db_agent
DB_CLAUDE_POSTGRES_ACCESS_MODE=restricted
DB_CLAUDE_POSTGRES_MCP_COMMAND=python
DB_CLAUDE_POSTGRES_MCP_PACKAGE=-m
DB_CLAUDE_POSTGRES_MCP_ENTRYPOINT=postgres_mcp

# Startup script options
DB_CLAUDE_MODE=interactive # interactive | api | check
DB_CLAUDE_API_PORT=8010
DB_CLAUDE_START_POSTGRES=auto
DB_CLAUDE_STOP_POSTGRES=false
