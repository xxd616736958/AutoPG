# AutoPG database tuning agent configuration
# Copy to .env or export these variables in your shell.

# LLM provider config is also supported through ~/.autopg/config.json.
DEEPSEEK_API_KEY=sk-...
AUTOPG_PROVIDER=deepseek
AUTOPG_MODEL=deepseek-v4-flash
AUTOPG_BASE_URL=https://api.deepseek.com/v1

# Built-in postgres_mcp config
AUTOPG_DATABASE_URI=postgresql://nncc@localhost:5432/db_agent
AUTOPG_POSTGRES_ACCESS_MODE=restricted
AUTOPG_POSTGRES_MCP_COMMAND=python
AUTOPG_POSTGRES_MCP_PACKAGE=-m
AUTOPG_POSTGRES_MCP_ENTRYPOINT=postgres_mcp

# Startup script options
AUTOPG_MODE=interactive # interactive | api | check
AUTOPG_API_PORT=8010
AUTOPG_START_POSTGRES=auto
AUTOPG_STOP_POSTGRES=false
